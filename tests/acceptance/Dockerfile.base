FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir uv
COPY pyproject.toml uv.lock README.md LICENSE ./
COPY src/ ./src/
RUN uv pip install -e "." --system
COPY tests/__init__.py* ./tests/
COPY tests/acceptance/conftest.py tests/acceptance/helpers.py ./tests/acceptance/
RUN touch tests/__init__.py tests/acceptance/__init__.py
ENV OPENFLUX_DB_PATH=/tmp/traces.db
